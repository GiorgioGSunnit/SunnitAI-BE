# =============================================================================
# .env.local.example — Variabili minime per development locale
# =============================================================================
# Copia questo file in .env e compila i valori per testare in locale.
#
# Per testare SOLO il parsing (no LLM): nessuna variabile necessaria
# Per testare con LLM: compila la sezione qui sotto
# =============================================================================

# ── LLM (self-hosted OpenAI-compatible endpoint) ──────────────────────────────
LLM_BASE_URL=https://<runpod-or-server>/v1
LLM_API_KEY=PASTE_YOUR_API_KEY
LLM_MODEL=nemotron-2-30B-A3B

# ── Embeddings (opzionale) ────────────────────────────────────────────────────
# LLM_EMBEDDING_BASE_URL=https://<runpod-or-server>/v1
# LLM_EMBEDDING_API_KEY=PASTE_YOUR_API_KEY
# LLM_EMBEDDING_MODEL=<embedding-model-name>

# ── Local storage ─────────────────────────────────────────────────────────────
LOCAL_STORAGE_PATH=/opt/sunnitai-be/storage
BLOB_CONTAINER_NAME=cdp-ext

# ── Filesystem watcher ────────────────────────────────────────────────────────
# Directory watched for new PDFs by the sunnitai-watcher service.
# Drop a PDF here → it is automatically ingested into Neo4J (if configured).
WATCH_DIR=/opt/sunnitai-be/inbox
# WATCHER_POLL_SECONDS=10   # how often to scan for new files (default: 10)

# ── Neo4J (optional) ──────────────────────────────────────────────────────────
# If NEO4J_URI is unset, the watcher still runs but skips the DB write step
# and saves the graph payload as JSON in <WATCH_DIR>/done/.
# NEO4J_URI=bolt://your-neo4j-host:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-neo4j-password-here
# NEO4J_DATABASE=neo4j
