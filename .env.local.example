# =============================================================================
# .env.local.example - Variabili minime per development locale
# =============================================================================
# Copia questo file in .env e compila i valori per testare in locale.
#
# Per testare SOLO il parsing (no LLM): nessuna variabile necessaria
# Per testare con LLM: compila la sezione Azure OpenAI o OpenAI
# =============================================================================

# --- Opzione A: Azure OpenAI (default) ---
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2024-08-01-preview
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/  # opzionale se usi LLM_BASE_URL

# --- Opzione B: OpenAI standard (alternativa) ---
# Decommentare e usare queste invece di Azure:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key
# LLM_MODEL=gpt-4o-mini

# --- LLM Factory (configurazione avanzata) ---
# LLM_PROVIDER=azure_openai
# LLM_BASE_URL=https://your-resource.openai.azure.com/
# LLM_MODEL=gpt-4o-mini
# LLM_API_VERSION=2024-08-01-preview
