# =============================================================================
# SunnitAI-BE — Environment Variables
#
# Copy to .env.production and fill in real values before deploying.
# Ask the team for the server-specific values.
# =============================================================================

# ── LLM (OpenAI-compatible server) ───────────────────────────────────────────
# URL of the LLM endpoint exposed by the team server (RunPod / vLLM / Ollama)
LLM_BASE_URL=http://SERVER_IP:PORT/v1
# API key — use "EMPTY" if the local server has no authentication
LLM_API_KEY=CHANGE_ME
# Model/deployment name on the server
LLM_MODEL=CHANGE_ME
# Provider (leave as "openai" — works with any OpenAI-compatible endpoint)
LLM_PROVIDER=openai

# ── LLM Fallback (optional — leave blank to use primary for both) ─────────────
LLM_BASE_URL_FALLBACK=
LLM_API_KEY_FALLBACK=
LLM_FALLBACK_MODEL=

# ── Embeddings (OpenAI-compatible embedding endpoint on server) ────────────────
# If the same server handles embeddings, set the model name.
# Leave LLM_EMBEDDING_BASE_URL blank to reuse LLM_BASE_URL.
LLM_EMBEDDING_MODEL=CHANGE_ME
LLM_EMBEDDING_BASE_URL=
LLM_EMBEDDING_API_KEY=

# ── Local Storage ─────────────────────────────────────────────────────────────
# Where blobs (PDFs, outputs, job state) are stored on the server filesystem.
LOCAL_STORAGE_PATH=/opt/sunnitai-be/storage
BLOB_CONTAINER_NAME=sunnitai

# ── App settings ──────────────────────────────────────────────────────────────
MODE=prod
IPVMAI=127.0.0.1
IPVMNER=127.0.0.1
VMAI_PORT=2025
FUNCTIONS_PORT=7071

# ── Optional: Translator ──────────────────────────────────────────────────────
TRANSLATOR_KEY=
TRANSLATOR_LOCATION=

# ── Optional: Search (leave blank to disable Azure AI Search) ─────────────────
SEARCH_KEY=
