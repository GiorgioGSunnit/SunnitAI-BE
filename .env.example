# === Azure OpenAI (principale) ===
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2024-08-01-preview
AZURE_API_VERSION_GPT4O=2024-12-01-preview

# === LLM Factory (alternativa) ===
LLM_PROVIDER=azure
LLM_BASE_URL=https://your-resource.openai.azure.com/
LLM_MODEL=gpt-4o
LLM_API_VERSION=2024-08-01-preview
OPENAI_API_KEY=your-api-key

# === Azure Blob Storage ===
CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
CONTAINER_NAME=cdp
CONTAINER_NAME_EXT=cdp-ext

# === Azure Search & Translator ===
SEARCH_KEY=your-search-key
TRANSLATOR_KEY=your-translator-key
TRANSLATOR_LOCATION=westeurope

# === App settings ===
AMENDING_MODE=false
MODE=dev
IPVMAI=127.0.0.1
IPVMNER=127.0.0.1
VMAI_PORT=2025
