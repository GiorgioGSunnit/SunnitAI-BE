# ── LLM (self-hosted OpenAI-compatible endpoint) ──────────────────────────────
LLM_BASE_URL=https://<runpod-or-server>/v1
LLM_API_KEY=PASTE_YOUR_API_KEY
LLM_MODEL=nemotron-2-30B-A3B

# ── Embeddings ─────────────────────────────────────────────────────────────────
LLM_EMBEDDING_BASE_URL=https://<runpod-or-server>/v1
LLM_EMBEDDING_API_KEY=PASTE_YOUR_API_KEY
LLM_EMBEDDING_MODEL=<embedding-model-name>

# ── Local storage (replaces Azure Blob) ────────────────────────────────────────
LOCAL_STORAGE_PATH=/opt/sunnitai-be/storage
BLOB_CONTAINER_NAME=cdp-ext

# ── App ────────────────────────────────────────────────────────────────────────
AMENDING_MODE=false

# ── Filesystem watcher ────────────────────────────────────────────────────────
WATCH_DIR=/opt/sunnitai-be/inbox
# WATCHER_POLL_SECONDS=10

# ── Neo4J (optional) ──────────────────────────────────────────────────────────
# NEO4J_URI=bolt://your-neo4j-host:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-neo4j-password-here
# NEO4J_DATABASE=neo4j
